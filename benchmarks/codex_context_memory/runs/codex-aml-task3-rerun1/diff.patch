+def load_recent_task_summaries(path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH) -> list[dict]:
+    summaries_path = Path(path)
+    if not summaries_path.exists():
+        return []
+    return json.loads(summaries_path.read_text(encoding="utf-8"))
+
+
+def save_recent_task_summary(
+    summary: dict,
+    path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH,
+    limit: int = 5,
+) -> list[dict]:
+    recent_summaries = load_recent_task_summaries(path)
+    updated_summaries = [dict(summary), *recent_summaries][: int(limit)]
+    Path(path).write_text(
+        json.dumps(updated_summaries, indent=2, sort_keys=True) + "\n",
+        encoding="utf-8",
+    )
