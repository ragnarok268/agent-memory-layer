 import unittest
+from pathlib import Path
 
 import app
 
 
 class AppTests(unittest.TestCase):
+    def local_test_path(self, filename, content="[]\n"):
+        path = Path(filename)
+        path.write_text(content, encoding="utf-8")
+        return path
+
     def test_default_config_is_local_only(self):
         self.assertTrue(app.is_configured())
 
     def test_project_summary_format(self):
         summary = app.summarize_project("demo", completed_tasks=2, open_tasks=3)
         self.assertEqual(app.format_summary(summary), "demo: 2 completed, 3 open")
+
+    def test_recent_task_summaries_persist_to_local_file(self):
+        summaries_path = self.local_test_path(".test_recent_task_summaries.json")
+        missing_path = Path(".test_missing_recent_task_summaries.json")
+        first = app.summarize_project("first", completed_tasks=1, open_tasks=4)
+        second = app.summarize_project("second", completed_tasks=2, open_tasks=3)
+
+        self.assertEqual(app.load_recent_task_summaries(missing_path), [])
+        app.save_recent_task_summary(first, summaries_path)
+        saved = app.save_recent_task_summary(second, summaries_path, limit=2)
+
+        self.assertEqual(saved, [second, first])
+        self.assertEqual(app.load_recent_task_summaries(summaries_path), [second, first])
+
+    def test_recent_task_summaries_respect_limit(self):
+        summaries_path = self.local_test_path(".test_recent_task_summaries_limit.json")
+
+        for index in range(3):
+            app.save_recent_task_summary(
+                app.summarize_project(f"task-{index}"),
+                summaries_path,
+                limit=2,
+            )
+
+        self.assertEqual(
+            app.load_recent_task_summaries(summaries_path),
+            [
+                app.summarize_project("task-2"),
+                app.summarize_project("task-1"),
+            ],
+        )
 
     def test_feature_flags_default_off(self):
         self.assertFalse(app.is_feature_enabled("experimental_summary_view"))
