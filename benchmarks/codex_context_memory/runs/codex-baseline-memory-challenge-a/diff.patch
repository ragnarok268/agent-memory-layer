+def load_recent_summaries(path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH) -> list[dict]:
+    summaries_path = Path(path)
+    if not summaries_path.exists():
+        return []
+    summaries = json.loads(summaries_path.read_text(encoding="utf-8"))
+    if not isinstance(summaries, list):
+        raise ValueError("recent summaries data must be a list")
+    return summaries
+
+
+def save_recent_summaries(
+    summaries: list[dict],
+    path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH,
+    limit: int = DEFAULT_RECENT_SUMMARIES_LIMIT,
+) -> list[dict]:
+    recent_summaries = list(summaries)[: max(0, int(limit))]
+    summaries_path = Path(path)
+    summaries_path.parent.mkdir(parents=True, exist_ok=True)
+    summaries_path.write_text(
+        json.dumps(recent_summaries, indent=2, sort_keys=True) + "\n",
+        encoding="utf-8",
+    )
+    return recent_summaries
+
+
+def add_recent_summary(
+    summary: dict,
+    path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH,
+    limit: int = DEFAULT_RECENT_SUMMARIES_LIMIT,
+) -> list[dict]:
+    recent_summaries = [dict(summary), *load_recent_summaries(path)]
+    return save_recent_summaries(recent_summaries, path, limit)
+
