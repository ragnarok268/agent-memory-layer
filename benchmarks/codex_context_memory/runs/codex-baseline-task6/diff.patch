@@ -53,3 +54,41 @@
 def normalize_status(value: str) -> str:
     return value.strip().lower()
 
+
+def scan_todo_comments(paths: str | Path | Iterable[str | Path]) -> list[dict]:
+    if isinstance(paths, (str, Path)):
+        scan_paths = [Path(paths)]
+    else:
+        scan_paths = [Path(path) for path in paths]
+
+    todos = []
+    for scan_path in scan_paths:
+        files = [scan_path] if scan_path.is_file() else sorted(path for path in scan_path.rglob("*") if path.is_file())
+        for file_path in files:
+            try:
+                lines = file_path.read_text(encoding="utf-8").splitlines()
+            except UnicodeDecodeError:
+                continue
+
+            for line_number, line in enumerate(lines, start=1):
+                stripped = line.strip()
+                if _is_todo_comment(stripped):
+                    todos.append(
+                        {
+                            "path": str(file_path),
+                            "line": line_number,
+                            "text": stripped,
+                        }
+                    )
+    return todos
+
+
+def format_todo_report(todos: list[dict]) -> str:
+    if not todos:
+        return "No TODO comments found."
+    return "\n".join(f"{todo['path']}:{todo['line']}: {todo['text']}" for todo in todos)
+
+
+def _is_todo_comment(line: str) -> bool:
+    comment_markers = ("#", "//", "/*", "*", "<!--")
+    return line.startswith(comment_markers) and "TODO" in line.upper()
