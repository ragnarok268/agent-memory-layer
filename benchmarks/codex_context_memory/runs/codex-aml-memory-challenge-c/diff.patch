 from __future__ import annotations
 
 import json
+import sys
 from pathlib import Path
 
 
@@ -53,3 +54,43 @@
 def normalize_status(value: str) -> str:
     return value.strip().lower()
 
+
+def maintenance_check(path: str | Path = "project_config.json") -> dict:
+    config_path = Path(path)
+    config = load_config(config_path)
+    issues = []
+
+    if not config.get("project_name"):
+        issues.append("project_name is missing")
+    if config.get("local_only") is not True:
+        issues.append("local_only must be true")
+
+    return {
+        "ok": not issues,
+        "config_path": str(config_path),
+        "issues": issues,
+    }
+
+
+def main(argv: list[str] | None = None, output=None) -> int:
+    args = list(sys.argv[1:] if argv is None else argv)
+    output = sys.stdout if output is None else output
+
+    if not args or args[0] in {"-h", "--help"}:
+        output.write("Usage: python app.py maintenance-check [config_path]\n")
+        return 0
+
+    command = args.pop(0)
+    if command != "maintenance-check":
+        output.write(f"Unknown command: {command}\n")
+        return 2
+
+    config_path = args[0] if args else "project_config.json"
+    report = maintenance_check(config_path)
+    output.write(json.dumps(report, indent=2, sort_keys=True))
+    output.write("\n")
+    return 0 if report["ok"] else 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
