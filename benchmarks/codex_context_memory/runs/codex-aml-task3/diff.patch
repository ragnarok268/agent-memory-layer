+def load_recent_task_summaries(path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH) -> list[dict]:
+    summaries_path = Path(path)
+    if not summaries_path.exists():
+        return []
+
+    summaries = json.loads(summaries_path.read_text(encoding="utf-8"))
+    if not isinstance(summaries, list):
+        raise ValueError("recent task summaries must be stored as a list")
+    return summaries
+
+
+def save_recent_task_summary(
+    summary: dict,
+    path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH,
+    limit: int = 5,
+) -> list[dict]:
+    if limit < 1:
+        raise ValueError("limit must be at least 1")
+
+    summaries_path = Path(path)
+    recent_summaries = load_recent_task_summaries(summaries_path)
+    recent_summaries.append(dict(summary))
+    recent_summaries = recent_summaries[-limit:]
+
+    summaries_path.parent.mkdir(parents=True, exist_ok=True)
+    summaries_path.write_text(
+        json.dumps(recent_summaries, indent=2, sort_keys=True) + "\n",
+        encoding="utf-8",
+    )
+    return recent_summaries
+
