+    def test_recent_task_summaries_start_empty_when_file_missing(self):
+        self.assertEqual(app.load_recent_task_summaries(TEST_SUMMARIES_PATH), [])
+
+    def test_save_recent_task_summary_persists_to_local_json_file(self):
+        summary = app.summarize_project("demo", completed_tasks=1, open_tasks=2)
+
+        recent = app.save_recent_task_summary(summary, TEST_SUMMARIES_PATH)
+
+        self.assertEqual(recent, [summary])
+        self.assertEqual(app.load_recent_task_summaries(TEST_SUMMARIES_PATH), [summary])
+
+    def test_save_recent_task_summary_keeps_only_limit(self):
+        for index in range(3):
+            app.save_recent_task_summary(
+                app.summarize_project(f"demo-{index}"),
+                TEST_SUMMARIES_PATH,
+                limit=2,
+            )
+
+        recent = app.load_recent_task_summaries(TEST_SUMMARIES_PATH)
+        self.assertEqual([summary["name"] for summary in recent], ["demo-1", "demo-2"])
+
 
 if __name__ == "__main__":
     unittest.main()
