+class FeatureRegistry:
+    """Local feature flag registry backed by an inspectable JSON file."""
+
+    def __init__(self, flags: dict[str, bool] | None = None) -> None:
+        self._flags = dict(DEFAULT_FEATURE_FLAGS)
+        if flags:
+            self._flags.update({name: bool(enabled) for name, enabled in flags.items()})
+
+    @classmethod
+    def from_file(cls, path: str | Path = "registry.json") -> "FeatureRegistry":
+        registry_path = Path(path)
+        if not registry_path.exists():
+            return cls()
+        return cls(json.loads(registry_path.read_text(encoding="utf-8")))
+
+    def is_enabled(self, flag_name: str) -> bool:
+        return bool(self._flags.get(flag_name, False))
+
+
