+def make_report_id(report: dict) -> str:
+    report_content = {key: value for key, value in report.items() if key != "report_id"}
+    payload = json.dumps(report_content, sort_keys=True, separators=(",", ":"), ensure_ascii=True)
+    return f"report-{hashlib.sha256(payload.encode('utf-8')).hexdigest()[:12]}"
+
+
+def export_report(report: dict) -> dict:
+    exported = dict(report)
+    exported["report_id"] = make_report_id(report)
+    return exported
+
