+from pathlib import Path
 import unittest
 
 import app
 
 
 class AppTests(unittest.TestCase):
+    def recent_summaries_path(self, name: str) -> Path:
+        path = Path.cwd() / name
+        path.unlink(missing_ok=True)
+        self.addCleanup(lambda: path.unlink(missing_ok=True))
+        return path
+
     def test_default_config_is_local_only(self):
         self.assertTrue(app.is_configured())
 
     def test_project_summary_format(self):
         summary = app.summarize_project("demo", completed_tasks=2, open_tasks=3)
         self.assertEqual(app.format_summary(summary), "demo: 2 completed, 3 open")
+
+    def test_recent_summaries_load_empty_when_missing(self):
+        path = self.recent_summaries_path(".test_recent_summaries_missing.json")
+
+        self.assertEqual(app.load_recent_summaries(path), [])
+
+    def test_recent_summaries_persist_to_local_file(self):
+        path = self.recent_summaries_path(".test_recent_summaries_persist.json")
+        summary = app.summarize_project("demo", completed_tasks=2, open_tasks=3)
+
+        app.save_recent_summaries([summary], path)
+
+        self.assertEqual(app.load_recent_summaries(path), [summary])
+
+    def test_add_recent_summary_keeps_newest_first_and_limit(self):
+        path = self.recent_summaries_path(".test_recent_summaries_limit.json")
+        old_summary = app.summarize_project("old", completed_tasks=1)
+        new_summary = app.summarize_project("new", open_tasks=2)
+        app.save_recent_summaries([old_summary], path)
+
+        recent = app.add_recent_summary(new_summary, path, limit=1)
+
+        self.assertEqual(recent, [new_summary])
+        self.assertEqual(app.load_recent_summaries(path), [new_summary])
 
     def test_feature_flags_default_off(self):
         self.assertFalse(app.is_feature_enabled("experimental_summary_view"))
