@@ -53,3 +53,42 @@
 def normalize_status(value: str) -> str:
     return value.strip().lower()
 
+
+def scan_todo_comments(root: str | Path) -> list[dict]:
+    root_path = Path(root)
+    if root_path.is_file():
+        candidate_paths = [root_path]
+        base_path = root_path.parent
+    else:
+        candidate_paths = sorted(path for path in root_path.rglob("*") if path.is_file())
+        base_path = root_path
+
+    findings = []
+    for path in candidate_paths:
+        try:
+            lines = path.read_text(encoding="utf-8").splitlines()
+        except UnicodeDecodeError:
+            continue
+
+        for line_number, line in enumerate(lines, start=1):
+            column = line.find("TODO")
+            if column == -1:
+                continue
+            findings.append(
+                {
+                    "path": str(path.relative_to(base_path)),
+                    "line": line_number,
+                    "column": column + 1,
+                    "text": line.strip(),
+                }
+            )
+    return findings
+
+
+def format_todo_report(findings: list[dict]) -> str:
+    if not findings:
+        return "No TODO comments found."
+    return "\n".join(
+        f"{finding['path']}:{finding['line']}:{finding['column']}: {finding['text']}"
+        for finding in findings
+    )
