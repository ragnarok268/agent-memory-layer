+def load_recent_summaries(path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH) -> list[dict]:
+    summaries_path = Path(path)
+    if not summaries_path.exists():
+        return []
+    return json.loads(summaries_path.read_text(encoding="utf-8"))
+
+
+def save_recent_summary(
+    summary: dict,
+    path: str | Path = DEFAULT_RECENT_SUMMARIES_PATH,
+    limit: int = 5,
+) -> list[dict]:
+    summaries_path = Path(path)
+    recent_summaries = load_recent_summaries(summaries_path)
+    recent_summaries.append(dict(summary))
+    limit = max(int(limit), 0)
+    recent_summaries = recent_summaries[-limit:] if limit else []
+    summaries_path.write_text(
+        json.dumps(recent_summaries, indent=2, sort_keys=True) + "\n",
+        encoding="utf-8",
+    )
+    return recent_summaries
+
+
