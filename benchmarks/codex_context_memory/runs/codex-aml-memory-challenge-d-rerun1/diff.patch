+class FeatureRegistry:
+    """Local, file-backed feature flag registry with default-off flags."""
+
+    def __init__(self, path: str | Path = DEFAULT_REGISTRY_PATH):
+        self.path = Path(path)
+        self._flags = self._load_flags()
+
+    def _load_flags(self) -> dict:
+        if not self.path.exists():
+            return {}
+
+        registry = json.loads(self.path.read_text(encoding="utf-8"))
+        return dict(registry.get("flags", {}))
+
+    def is_enabled(self, flag_name: str) -> bool:
+        flag = self._flags.get(flag_name)
+        if isinstance(flag, dict):
+            return bool(flag.get("enabled", False))
+        return bool(flag) if flag is not None else False
 
 
