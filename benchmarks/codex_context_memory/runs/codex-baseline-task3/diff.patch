+    def test_recent_task_summaries_persist_to_disk(self):
+        summary_path = TEST_DIR / "test_recent_task_summaries.json"
+        summary_path.write_text("[]\n", encoding="utf-8")
+        try:
+            summary = app.summarize_project("demo", completed_tasks=2, open_tasks=3)
+
+            saved = app.save_recent_task_summary(summary, path=summary_path)
+
+            self.assertEqual(saved, [summary])
+            self.assertEqual(app.load_recent_task_summaries(summary_path), [summary])
+        finally:
+            remove_if_possible(summary_path)
+
+    def test_recent_task_summaries_keep_limit(self):
+        summary_path = TEST_DIR / "test_recent_task_summaries_limit.json"
+        summary_path.write_text("[]\n", encoding="utf-8")
+        try:
+            for index in range(3):
+                app.save_recent_task_summary(
+                    app.summarize_project(f"demo-{index}"),
+                    path=summary_path,
+                    limit=2,
+                )
+
+            self.assertEqual(
+                [summary["name"] for summary in app.load_recent_task_summaries(summary_path)],
+                ["demo-1", "demo-2"],
+            )
