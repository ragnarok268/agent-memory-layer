 def normalize_status(value: str) -> str:
     return value.strip().lower()
 
+
+def _normalize_command(command: str | list[str]) -> list[str]:
+    if isinstance(command, str):
+        return shlex.split(command)
+    return [str(part) for part in command]
+
+
+def run_maintenance_commands(config: dict | None = None) -> list[subprocess.CompletedProcess]:
+    active_config = config or load_config()
+    commands = active_config.get("maintenance_commands", [])
+    results = []
+    for command in commands:
+        results.append(subprocess.run(_normalize_command(command), check=True))
+    return results
+
+
+def main(argv: list[str] | None = None) -> int:
+    import argparse
+
+    parser = argparse.ArgumentParser(description="Sample local project utilities.")
+    subparsers = parser.add_subparsers(dest="command")
+    maintenance_parser = subparsers.add_parser(
+        "maintenance",
+        help="Run maintenance commands from project config.",
+    )
+    maintenance_parser.add_argument(
+        "--config",
+        default="project_config.json",
+        help="Path to project config.",
+    )
+
+    args = parser.parse_args(argv)
+    if args.command == "maintenance":
+        run_maintenance_commands(load_config(args.config))
+        return 0
+
+    parser.print_help()
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
