@@ -53,3 +54,55 @@
 def normalize_status(value: str) -> str:
     return value.strip().lower()
 
+
+def build_maintenance_report(config_path: str | Path = "project_config.json") -> dict:
+    config = load_config(config_path)
+    return {
+        "configured": is_configured(config),
+        "local_only": config.get("local_only") is True,
+        "project_name": config.get("project_name", ""),
+        "feature_flags": dict(FEATURE_FLAGS),
+    }
+
+
+def format_maintenance_report(report: dict) -> str:
+    flags = ", ".join(
+        f"{name}={str(enabled).lower()}"
+        for name, enabled in sorted(report["feature_flags"].items())
+    )
+    return "\n".join(
+        [
+            "Maintenance report",
+            f"project_name: {report['project_name']}",
+            f"configured: {str(report['configured']).lower()}",
+            f"local_only: {str(report['local_only']).lower()}",
+            f"feature_flags: {flags or 'none'}",
+        ]
+    )
+
+
+def main(argv: list[str] | None = None) -> int:
+    parser = argparse.ArgumentParser(description="Local project helper commands.")
+    subparsers = parser.add_subparsers(dest="command")
+
+    maintenance_parser = subparsers.add_parser(
+        "maintenance",
+        help="print a local-only maintenance report",
+    )
+    maintenance_parser.add_argument(
+        "--config",
+        default="project_config.json",
+        help="path to the project config file",
+    )
+
+    args = parser.parse_args(argv)
+    if args.command == "maintenance":
+        print(format_maintenance_report(build_maintenance_report(args.config)))
+        return 0
+
+    parser.print_help()
+    return 0
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
